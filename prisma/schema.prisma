// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum ItemCategory {
  MEDICATION
  SUPPLY
}

model Profile {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  role               Role     @default(RECEPTIONIST)
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())

  appointments     Appointment[] @relation("DoctorAppointments")
  sentMessages     Message[]     @relation("MessageSender")
  receivedMessages Message[]     @relation("MessageReceiver")
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  receiverId String
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender   Profile @relation("MessageSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver Profile @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  dob       DateTime
  gender    Gender
  phone     String
  address   String?
  createdAt DateTime @default(now())

  appointments Appointment[]
}

model Appointment {
  id          String            @id @default(uuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      Profile           @relation("DoctorAppointments", fields: [doctorId], references: [id])
  scheduledAt DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime          @default(now())

  invoice      Invoice?
  prescription Prescription?
}

model Invoice {
  id            String        @id @default(uuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Int
  status        InvoiceStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  paidAt        DateTime?
}

model Medication {
  id               String          @id @default(uuid())
  name             String
  unit             String
  stock            Int             @default(0)
  reorderThreshold Int             @default(10)
  category         ItemCategory    @default(MEDICATION)
  createdAt        DateTime        @default(now())

  stockMovements StockMovement[]
}

model StockMovement {
  id           String     @id @default(uuid())
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  delta        Int
  reason       String
  createdAt    DateTime   @default(now())
}

model Prescription {
  id            String             @id @default(uuid())
  appointmentId String             @unique
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  items         PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicationName String
  dosage         String
  duration       String
  notes          String?
  createdAt      DateTime     @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorName  String
  action     String
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())
}
